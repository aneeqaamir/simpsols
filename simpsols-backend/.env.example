# SimpSols Backend Environment Variables
# Copy this to .env and fill in your values

# Frontend URL (for CORS)
FRONTEND_URL=https://simpsols.com

# Blog API Key (used by AI agents to post articles)
BLOG_API_KEY=your_secret_key_here

# Email notifications (optional)
# SENDGRID_API_KEY=your_key_here
# NOTIFICATION_EMAIL=hello@simpsols.com
