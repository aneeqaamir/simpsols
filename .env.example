# SimpSols Frontend Environment Variables
# Copy this to .env.local and fill in your values

# Gemini API Key (for SimpBot)
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here

# Calendly booking URL
REACT_APP_CALENDLY_URL=https://calendly.com/your-link-here

# Backend API URL (leave empty to use static data only)
REACT_APP_API_URL=https://your-backend.railway.app
